{
  "pluginAlias": "CrestronHomePlatform",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "required": [
      "name",
      "crestronHost",
      "token"
    ],
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Crestron Home Platform"
      },
      "crestronHost": {
        "title": "Crestron Processor IP Address",
        "type": "string",
        "format": "hostname"
      },
      "token": {
        "title": "API Auth Token",
        "type": "string"
      },
      "enabledTypes": {
        "title": "Enabled devices",
        "type": "array",
        "uniqueItems": true,
        "items": {
          "title": "Type",
          "type": "string",
          "enum": [
            "Switch",
            "Dimmer",
            "Shade",
            "Scene",
            "Thermostat",
            "DoorLock",
            "SecuritySystem"
          ]
        }
      },
      "updateInterval": {
        "title": "Refresh Devices Interval (seconds). Default 30",
        "default": 30,
        "type": "integer",
        "minimum": 10,
        "maximum": 540
      }
    }
  }
}
